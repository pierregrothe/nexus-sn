# NEXUS environment variables
# Copy to .env for local development. Never commit .env.
# All secrets default to OS keychain. These env vars are for CI and scripted use.

# Claude Enterprise API key (overrides keychain)
# NEXUS_CLAUDE_API_KEY=sk-ant-...

# ServiceNow instance credentials (overrides keychain, per-profile)
# NEXUS_SN_PASSWORD_DEV12345=your-password

# Override config file location (default: ~/.nexus/config.yaml)
# NEXUS_CONFIG_PATH=/path/to/config.yaml

# Log level (default: WARNING)
# NEXUS_LOG_LEVEL=DEBUG
